<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
       default-autowire="constructor">
  <bean id="jenkinsBridgeSettingsProvider"
        class="com.jetbrains.teamcity.jenkinsbridge.settings.JenkinsBridgeSettingsProvider"/>

  <bean id="jenkinsBridgeHttpClient"
        class="com.jetbrains.teamcity.jenkinsbridge.http.BridgeHttpClient"/>

  <bean id="jenkinsClient"
        class="com.jetbrains.teamcity.jenkinsbridge.jenkins.JenkinsClient"/>

  <bean id="teamCityClient"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityClient"/>

  <bean id="teamCityRunningBuildLocator"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityRunningBuildLocator"/>

  <bean id="teamCityBuildQueuer"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityBuildQueuer"/>

  <bean id="teamCityBuildStarter"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityBuildStarter"/>

  <bean id="teamCityBuildLogger"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityBuildLogger"/>

  <bean id="teamCityTestReporter"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityTestReporter"/>

  <bean id="teamCityStageReporter"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityStageReporter"/>

  <bean id="teamCityArtifactPublisher"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityArtifactPublisher"/>

  <bean id="teamCityBuildFinisher"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityBuildFinisher"/>

  <bean id="teamCityPipelineChainService"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityPipelineChainService"/>

  <bean id="buildMirrorStore"
        class="com.jetbrains.teamcity.jenkinsbridge.persistence.BuildMirrorStore"/>

  <bean id="bridgeBuildFeature"
        class="com.jetbrains.teamcity.jenkinsbridge.feature.BridgeBuildFeature"/>

  <bean id="mirroredJobProvider"
        class="com.jetbrains.teamcity.jenkinsbridge.feature.MirroredJobProvider"/>

  <bean id="jenkinsJobImporter"
        class="com.jetbrains.teamcity.jenkinsbridge.feature.JenkinsJobImporter"/>

  <bean id="jenkinsBridgeImportController"
        class="com.jetbrains.teamcity.jenkinsbridge.web.JenkinsBridgeImportController"/>

  <bean id="jenkinsBridgeImportTab"
        class="com.jetbrains.teamcity.jenkinsbridge.web.JenkinsBridgeImportTab"/>

  <bean id="jenkinsTriggerController"
        class="com.jetbrains.teamcity.jenkinsbridge.web.JenkinsTriggerController"/>

  <bean id="jenkinsTriggerTab"
        class="com.jetbrains.teamcity.jenkinsbridge.web.JenkinsTriggerTab"/>

  <bean id="jenkinsBuildResultExtension"
        class="com.jetbrains.teamcity.jenkinsbridge.web.JenkinsBuildResultExtension"
        destroy-method="dispose"/>

  <bean id="jenkinsBuildSummaryExtension"
        class="com.jetbrains.teamcity.jenkinsbridge.web.JenkinsBuildSummaryExtension"
        destroy-method="dispose"/>

  <bean id="teamCityBuildMirrorService"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityBuildMirrorService"/>

  <bean id="jenkinsBridgePollingService"
        class="com.jetbrains.teamcity.jenkinsbridge.polling.JenkinsBridgePollingService"/>

  <bean id="jenkinsBridgeServerLifecycle"
        class="com.jetbrains.teamcity.jenkinsbridge.polling.JenkinsBridgeServerLifecycle"
        destroy-method="dispose"/>

  <bean id="jenkinsStorageType"
        class="com.jetbrains.teamcity.jenkinsbridge.artifactstorage.JenkinsStorageType"/>

  <bean id="jenkinsArtifactContentProvider"
        class="com.jetbrains.teamcity.jenkinsbridge.artifactstorage.JenkinsArtifactContentProvider"/>

  <bean id="jenkinsArtifactDownloadProcessor"
        class="com.jetbrains.teamcity.jenkinsbridge.artifactstorage.JenkinsArtifactDownloadProcessor"/>

  <bean id="jenkinsArtifactInfoUtils"
        class="com.jetbrains.teamcity.jenkinsbridge.artifactstorage.JenkinsArtifactInfoUtils"/>

  <bean id="jenkinsStorageAutomaticActivator"
        class="com.jetbrains.teamcity.jenkinsbridge.artifactstorage.JenkinsStorageAutomaticActivator"/>
</beans>
