<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
       default-autowire="constructor">
  <bean id="jenkinsBridgeSettingsProvider"
        class="com.jetbrains.teamcity.jenkinsbridge.settings.JenkinsBridgeSettingsProvider"/>

  <bean id="jenkinsBridgeHttpClient"
        class="com.jetbrains.teamcity.jenkinsbridge.http.BridgeHttpClient"/>

  <bean id="jenkinsClient"
        class="com.jetbrains.teamcity.jenkinsbridge.jenkins.JenkinsClient"/>

  <bean id="teamCityClient"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityClient"/>

  <bean id="jenkinsBuildMappingStore"
        class="com.jetbrains.teamcity.jenkinsbridge.mapping.JenkinsBuildMappingStore"/>

  <bean id="teamCityBuildMirrorService"
        class="com.jetbrains.teamcity.jenkinsbridge.teamcity.TeamCityBuildMirrorService"/>

  <bean id="jenkinsBridgePollingService"
        class="com.jetbrains.teamcity.jenkinsbridge.polling.JenkinsBridgePollingService"/>

  <bean id="jenkinsBridgeServerLifecycle"
        class="com.jetbrains.teamcity.jenkinsbridge.polling.JenkinsBridgeServerLifecycle"
        destroy-method="dispose"/>
</beans>
